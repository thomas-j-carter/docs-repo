{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["build/**", "dist/**", ".docusaurus/**"]
    },
    "docs:validate": {
      "dependsOn": ["^docs:validate"],
      "outputs": []
    },
    "docs:build:public": {
      "dependsOn": ["^docs:build:public"],
      "outputs": ["build/**"]
    },
    "docs:build:internal": {
      "dependsOn": ["^docs:build:internal"],
      "outputs": ["build/**"]
    }
  }
}
